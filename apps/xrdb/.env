# XRDB environment template
#
# Copy this file to .env and fill in the values for your deployment.
# Only the values in this file are needed for a normal self-hosted setup.
# Advanced tuning and internal override variables are documented in variables.md which can be found here: https://github.com/IbbyLabs/XRDB/blob/main/variables.md.

# ── Deployment ──────────────────────────────────────────────────────────────

# XRDB_PORT
# Host port used by local-compose.yaml when running without the stack template.
# The container listens on port 3000 internally.
# XRDB_PORT=3000

# DOCKER_NETWORK_EXTERNAL
# Set true when the Docker network already exists outside this repo.
# DOCKER_NETWORK_EXTERNAL=true

# XRDB_IMAGE_TAG
# Docker image tag used by compose.yaml. Use latest for stable releases or dev for the latest development build.
# XRDB_IMAGE_TAG=latest

# ── Proxy networking ─────────────────────────────────────────────────────────

# HTTP_PROXY
# HTTPS_PROXY
# Optional outbound proxy if your server routes traffic through something like gluetun.
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# ── Access and security ───────────────────────────────────────────────────────

# XRDB_TRUST_PROXY_HEADERS
# Trust forwarded host and protocol headers from a reverse proxy.
# Enable when XRDB sits behind Traefik or another proxy that sets forwarded headers.
# XRDB_TRUST_PROXY_HEADERS=true

# XRDB_REQUEST_API_KEY
# Single shared key for render and proxy access.
# Use this when you want to protect a private host with one key.
# XRDB_REQUEST_API_KEY=

# XRDB_REQUEST_API_KEYS
# Comma-separated list of valid request keys.
# Use this when you need multiple valid keys instead of one shared key.
# XRDB_REQUEST_API_KEYS=

# XRDB_PROXY_ALLOWED_ORIGINS
# CORS allowlist for proxy responses.
# Use * for an open proxy host or a comma-separated list for a stricter setup.
# XRDB_PROXY_ALLOWED_ORIGINS=*

# XRDB_CONFIG_ENCRYPTION_KEY
# 64 hex-character string (32 bytes) used to encrypt saved config profiles at rest.
# If not set, a key is auto-generated on first boot and written to data/.config-key.
# Set this explicitly in production and back it up. Losing the key makes existing profiles unreadable.
# Generate with: openssl rand -hex 32
# XRDB_CONFIG_ENCRYPTION_KEY=

# XRDB_INACTIVE_CONFIG_PRUNE_DAYS
# Days of inactivity before a saved config profile is deleted on startup.
# Set to -1 (default) to disable pruning.
# XRDB_INACTIVE_CONFIG_PRUNE_DAYS=-1

# ADMIN_KEY
# Set a strong unique key to enable the admin dashboard at /admin.
# Leave empty to disable the admin panel entirely (returns 404).
# Generate with: openssl rand -hex 32
# ADMIN_KEY=

# ── Instance customization ────────────────────────────────────────────────────

# XRDB_INSTANCE_HTML
# Optional raw HTML injected above the mode cards on the entry page.
# XRDB_INSTANCE_HTML=

# XRDB_DEFAULT_EPISODE_PROFILE_ID
# UUID of the saved config profile applied to episode thumbnail requests by default.
# When set, any thumbnail URL without an explicit ?config= parameter will use this profile
# automatically, so AIOMetadata-generated bare URLs include your configured badge and rating
# settings without manually embedded params.
# Set this to the profile ID shown in the configurator Export section.
# XRDB_DEFAULT_EPISODE_PROFILE_ID=

# ── Core provider credentials ─────────────────────────────────────────────────

# XRDB_TMDB_READ_ACCESS_TOKEN
# Preferred TMDB read access token for image rendering, search, and proxy translation.
# TMDB_READ_ACCESS_TOKEN is also accepted.
# XRDB_TMDB_READ_ACCESS_TOKEN=

# XRDB_TMDB_API_KEY
# TMDB v3 API key fallback.
# TMDB_API_KEY and TMDB_KEY are also accepted.
# XRDB_TMDB_API_KEY=

# MDBLIST_API_KEY
# MDBList key used as a fallback for rating aggregation on hosted instances.
# MDBLIST_API_KEY=

# MDBLIST_API_KEYS
# Optional comma-separated pool of MDBList keys for larger shared hosts.
# MDBLIST_API_KEYS=

# ── Optional providers ────────────────────────────────────────────────────────

# XRDB_MAL_CLIENT_ID
# MyAnimeList v2 client id for direct MAL lookups.
# If blank, XRDB falls back to Jikan where possible.
# XRDB_MAL_CLIENT_ID=

# XRDB_TRAKT_CLIENT_ID
# Trakt client id for direct Trakt rating lookups.
# XRDB_TRAKT_CLIENT_ID=

# OMDB_KEY
# OMDb API key for poster lookups when posterArtworkSource=omdb.
# XRDB_OMDB_API_KEY and OMDB_API_KEY are also accepted.
# OMDB_KEY=

# XRDB_FANART_API_KEY
# Fanart API key used as a fallback when the user does not supply fanartKey.
# FANART_API_KEY is also accepted.
# XRDB_FANART_API_KEY=

# XRDB_FANART_CLIENT_KEY
# Fanart client key.
# FANART_CLIENT_KEY is also accepted.
# XRDB_FANART_CLIENT_KEY=

# SIMKL_CLIENT_ID
# SIMKL client id for direct SIMKL rating lookups.
# SIMKL_CLIENT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────

# NODE_ENV=production

# XRDB_LOG_LEVEL
# Server log threshold. debug and info write to STDOUT. warn and error write to STDERR.
# XRDB_LOG_LEVEL=info

# XRDB_REQUEST_LOG_LEVEL
# Optional override for routine image request logs. Leave unset to keep request logs off.
# Accepted: off, debug, info, warn, error
# XRDB_REQUEST_LOG_LEVEL=off

